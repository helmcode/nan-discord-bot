# Discord bot credentials
DISCORD_TOKEN=
DISCORD_GUILD_ID=

# LiteLLM API for LLM and embeddings
LITELLM_BASE_URL=https://api.nan.builders/v1
LITELLM_API_KEY=

# Knowledge base settings
EMBEDDING_MODEL=qwen3-embedding
EMBEDDING_DIM=4096
TOP_K=5

# Bot will only respond when mentioned in these channels (comma-separated IDs)
ALLOWED_CHANNELS=

# Daily AI news (optional)
# Channel ID where daily AI news will be posted
NEWS_CHANNEL_ID=
# Hour of day to send news (0-23), default 9
NEWS_SEND_HOUR=9
# Comma-separated RSS feed URLs for news (default: 6 AI-focused feeds)
NEWS_FEEDS=https://news.ycombinator.com/front,https://techcrunch.com/category/artificial-intelligence/feed/,https://www.theverge.com/rss/ai-artificial-intelligence/index.xml,https://feeds.arstechnica.com/arstechnica/technology-lab,https://www.technologyreview.com/feed/,https://rss.art19.com/the-latest-artificial-intelligence-news-updates-from-mit-technology-review.xml
